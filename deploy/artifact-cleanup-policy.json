[
  {
    "name": "delete-images-older-than-30-days",
    "action": {
      "type": "Delete"
    },
    "condition": {
      "tagState": "any",
      "olderThan": "2592000s"
    }
  },
  {
    "name": "keep-production-image",
    "action": {
      "type": "Keep"
    },
    "condition": {
      "tagState": "tagged",
      "tagPrefixes": [
        "production"
      ]
    }
  },
  {
    "name": "keep-three-most-recent-images",
    "action": {
      "type": "Keep"
    },
    "mostRecentVersions": {
      "keepCount": 3
    }
  }
]

